{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/quiz",
      "destination": "/quiz.html"
    },
    {
      "source": "/dashboard",
      "destination": "/project/dashboard/index.html"
    },
    {
      "source": "/dashboard/",
      "destination": "/project/dashboard/index.html"
    },
    {
      "source": "/health",
      "destination": "/api/health"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), geolocation=(), payment=()"
        }
      ]
    },
    {
      "source": "/project/dashboard/data.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0"
        }
      ]
    },
    {
      "source": "/project/dashboard/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0"
        }
      ]
    }
  ]
}
